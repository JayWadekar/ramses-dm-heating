&RUN_PARAMS
poisson=.true.
hydro=.true.
pic=.true.
static_dm=.true.
nrestart=0
nremap=0
ncontrol=1
nstepmax=2
verbose=.false.
/

&AMR_PARAMS
levelmin=4
levelmax=4
ngridmax=10000
npartmax=100
boxlen=1.0
/

&OUTPUT_PARAMS
foutput=1
noutput=1
tout=10.0
/

&INIT_PARAMS
initfile='../dm_particle_ic'
nregion=1
region_type='square'
x_center=0.5
y_center=0.5
z_center=0.5
length_x=10.0
length_y=10.0
length_z=10.0
exp_region=10.0
d_region=1.0d-6
u_region=0.0
v_region=0.0
w_region=0.0
p_region=1.0d-6
/

&HYDRO_PARAMS
courant_factor=0.1
/

&POISSON_PARAMS
self_gravity=.true.
epsilon=1d-4
cg_levelmin=100
/

&REFINE_PARAMS
m_refine=7*-1.0
/
